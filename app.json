{
  "expo": {
    "name": "Recipely",
    "slug": "recipely",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EE8941",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "infoPlist": {
              "NSAllowsArbitraryLoads": true,
              "UIBackgroundModes": ["audio"]
            },
            "useFrameworks": "static"
          },
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-router",
        {
          "root": "presentation/app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EE8941",
          "dark": {
            "backgroundColor": "#EE8941"
          }
        }
      ],
      "expo-localization",
      "expo-video",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "sounds": ["./assets/sounds/alarm.mp3"],
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Recipely accesses your photos to add them to recipes.",
          "cameraPermission": "Recipely accesses your camera to take photos and videos for recipes."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/crashlytics",
      "@react-native-firebase/auth",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.421167568469-fg6bdiun08t9iebtnhg1ulnvu9f4bnne"
        }
      ],
      "./plugins/withAndroidReleaseSigning"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
