# ---------------------------------------------------------------------------
# Recipely frontend environment
#
# Which BACKEND a build talks to is chosen automatically by the build variant
# (APP_VARIANT), not by an env var:
#   • APP_VARIANT=development  → https://dev-api.recipely.net  (bundle …app.dev)
#   • APP_VARIANT=production   → https://api.recipely.net      (bundle …app)
# Selected in infrastructure/constants/api.ts via extra.variant (app.config.ts).
# Use the *:dev npm scripts (start:dev / web:dev / android:dev / ios:dev) to run
# the development variant locally. Override the URL only for one-off testing:
#   EXPO_PUBLIC_API_BASE_URL=
#   EXPO_PUBLIC_WEB_APP_URL=
# ---------------------------------------------------------------------------

# API encryption key (32-byte hex). Required on every build target.
EXPO_PUBLIC_API_AES_KEY=

# Google Sign-In Web OAuth client ID (type=3) — bundled into the APK,
# matches Firebase Authentication → Web client ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Firebase Web SDK config (only consumed by the web bundle —
# infrastructure/firebase/firebase-init.web.ts). Values are technically
# public (they identify the Firebase project) but are read from env so they
# stay out of git. Copy from Firebase Console → Project settings → Your
# apps → SDK setup and configuration.
#
# Dev and prod share the same Firebase project (recipely-c05fc), so most
# values below are identical for both. Only APP_ID and MEASUREMENT_ID differ:
# point them at the prod Web app (app-recipely) or the dev Web app
# (app-recipely-dev) depending on which variant you build locally.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
