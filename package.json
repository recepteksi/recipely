{
  "name": "recipely",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "APP_VARIANT=development expo start",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=development expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "APP_VARIANT=development expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "release:patch": "npm version patch -m 'chore(release): v%s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'chore(release): v%s' && git push --follow-tags",
    "release:major": "npm version major -m 'chore(release): v%s' && git push --follow-tags"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "axios": "^1.7.9",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "~16.0.8",
    "expo-build-properties": "^55.0.13",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "sharp": "^0.34.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "lint-staged": "^17.0.5",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
    ],
    "moduleNameMapper": {
      "^@core/(.*)$": "<rootDir>/core/$1",
      "^@domain/(.*)$": "<rootDir>/domain/$1",
      "^@infrastructure/(.*)$": "<rootDir>/infrastructure/$1",
      "^@application/(.*)$": "<rootDir>/application/$1",
      "^@presentation/(.*)$": "<rootDir>/presentation/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "jest --bail --findRelatedTests --passWithNoTests"
    ]
  },
  "private": true
}
