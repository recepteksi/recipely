{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@core/*": ["./core/*"],
      "@domain/*": ["./domain/*"],
      "@infrastructure/*": ["./infrastructure/*"],
      "@application/*": ["./application/*"],
      "@presentation/*": ["./presentation/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
